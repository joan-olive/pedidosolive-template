---
import DashBoardLayout from "../../layouts/dashboard/DashBoardLayout.astro";
import DashboardNav from "../../components/DashboardNav.astro";
import AddOrderForm from "../../components/AddOrderForm.astro";
---

<DashBoardLayout title="Agregar pedido">
    <div class="w-full md:max-w-7xl mx-auto flex flex-col relative">
        <header class="flex flex-col gap-3 my-7 md:mt-14 w-full md:w-7xl mx-auto">
            <h1 class="text-4xl font-semibold tracking-wide text-gray-900 uppercase">
                Agregar pedido
            </h1>
            <p class="text-gray-600 text-base max-w-3xl leading-relaxed">
                Agrega un pedido de un cliente en la base de datos
            </p>
        </header>
        <DashboardNav />
        
        <div class="w-full flex flex-col justify-center items-center">
            <AddOrderForm className="flex flex-col my-10 w-full md:max-w-xl animate-fade-in-up" />
        </div>
    </div>
</DashBoardLayout>