---
import Layout from "../../../layouts/Layout.astro";
import { getSupabaseServerClient } from "../../../lib/supabase";

const id = Astro.url.searchParams.get("id");
const supabase = getSupabaseServerClient(Astro);
const user = Astro.locals.user;

const { data: usuario, error } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", id)
    .single();

if (error || !usuario) {
    return Astro.redirect("/dashboard/users");
}

let success = false;
let errorMessage = "";
let fieldErrors = {
    current_password: false,
    new_password: false,
    new_password_confirmation: false,
};

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();

    const current_password =
        formData.get("current_password")?.toString().trim() ?? "";
    const new_password = formData.get("new_password")?.toString().trim() ?? "";
    const new_password_confirmation =
        formData.get("new_password_confirmation")?.toString().trim() ?? "";

    if (!current_password) fieldErrors.current_password = true;
    if (!new_password) fieldErrors.new_password = true;
    if (!new_password_confirmation)
        fieldErrors.new_password_confirmation = true;

    const errorCount = Object.values(fieldErrors).filter(Boolean).length;
    if (!errorMessage) {
        if (errorCount === Object.keys(fieldErrors).length) {
            errorMessage = "Todos los campos son obligatorios";
        } else if (errorCount > 0) {
            errorMessage = "Hay campos obligatorios sin rellenar";
        }
    }
}
---

<Layout title="Cambio de contraseña">
    <div class="w-full flex flex-col justify-center items-center py-10 px-2">
        <div class="w-full md:max-w-xl flex justify-center items-center flex-col py-10">
            <div class="hidden justify-center items-center w-full" id="success-alert">
                <span class="text-green-500 flex justify-center items-center gap-1 text-wrap animate-fade-in">
                    <i class="icon-[icon-park-outline--success]" />
                    La contraseña se ha actualizado correctamente
                </span>
            </div>
        </div>
        <form
            id="editar-contrasenya-form"
            class="bg-white rounded-xl w-full md:max-w-xl shadow-lg border border-black/10 md:p-6 p-4 space-y-6 animate-fade-in-up"
            method="POST"
            action="/api/change-password"
        >
            <div class="flex justify-between items-start">
                <h2 class="text-lg font-semibold text-gray-900 uppercase">
                    Modifica tu contraseña
                    <span class="block text-black/50 font-normal text-sm">
                        {usuario.id}
                    </span>
                </h2>
            </div>
            <div class="w-full flex justify-center items-center">
                <div
                    class="w-full h-px bg-black/15 rounded-full origin-center animate-width"
                >
                </div>
            </div>
            <div class="grid grid-cols-1 gap-4">
                <div>
                    <label
                        class="block text-xs font-semibold uppercase text-gray-500 mb-1"
                        for="company_name"
                    >
                        Contraseña actual
                    </label>
                    <input
                        type="password"
                        placeholder="Contraseña actual"
                        name="current_password"
                        class="original w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm edit-form-input"
                    />
                </div>

                <div>
                    <label
                        class="block text-xs font-semibold uppercase text-gray-500 mb-1"
                        for="contact_email"
                    >
                        Contraseña nueva
                    </label>
                    <input
                        type="password"
                        name="new_password"
                        placeholder="Contraseña nueva"
                        class="original w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm edit-form-input peer"
                    />
                </div>

                <div>
                    <label
                        class="block text-xs font-semibold uppercase text-gray-500 mb-1"
                        for="contact_email"
                    >
                        Confirma la contraseña nueva
                    </label>
                    <input
                        type="password"
                        name="new_password_confirmation"
                        placeholder="Confirma la contraseña nueva"
                        class="original w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm edit-form-input peer"
                    />
                </div>

                <div class="hidden justify-start items-center w-full px-1 text-sm" id="errors-alert">
                    <span class="text-red-700 flex justify-center items-center gap-2 animate-fade-in-up">
                        <i class="icon-[streamline-sharp--password-block-remix]" />
                        <span id="form-errors"></span>
                    </span>
                </div>
            </div>

            <div
                class="flex flex-col md:flex-row justify-start w-full md:justify-between items-center gap-2"
            >
                <button
                    disabled
                    id="saveButton"
                    type="submit"
                    class="cursor-not-allowed opacity-50 w-full px-4 md:py-2 py-3 rounded-lg bg-[#013485] hover:bg-[#012b6d] text-white text-sm font-medium transition-all"
                >
                    Guardar cambios
                </button>
            </div>
        </form>
    </div>
</Layout>

<script is:inline>
    document.addEventListener("astro:page-load", () => {
        const form = document.getElementById("editar-contrasenya-form");
        const saveButton = document.getElementById("saveButton");
        const errorsAlert = document.getElementById("errors-alert");
        const errorsText = document.getElementById("form-errors");
        const successAlert = document.getElementById("success-alert");
    
        if (!form || !saveButton) return;
    
        const fields = Array.from(form.querySelectorAll("input.original"));
    
        const resetButton = () => {
            saveButton.disabled = true;
            saveButton.classList.add(
                "cursor-not-allowed",
                "bg-[#013485]/50",
                "opacity-50"
            );
            saveButton.classList.remove("bg-[#013485]", "cursor-pointer");
        };
    
        const hideAlerts = () => {
            errorsAlert.classList.add("hidden");
            errorsAlert.classList.remove("flex");
            successAlert.classList.add("hidden");
            successAlert.classList.remove("flex");
            errorsText.textContent = "";
        };
    
        const hasAllValues = () =>
            fields.every((field) => field.value.trim() !== "");
    
        const updateButtonState = () => {
            hideAlerts();
    
            if (hasAllValues()) {
                saveButton.disabled = false;
                saveButton.classList.remove(
                    "cursor-not-allowed",
                    "bg-[#013485]/50",
                    "opacity-50"
                );
                saveButton.classList.add("bg-[#013485]", "cursor-pointer");
            } else {
                resetButton();
            }
        };
    
        fields.forEach((field) => {
            field.addEventListener("input", updateButtonState);
            field.addEventListener("change", updateButtonState);
        });
    
        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            hideAlerts();
    
            const res = await fetch(form.action, {
                method: "POST",
                body: new FormData(form),
            });
    
            if (res.ok) {
                form.reset();
                resetButton();
                
                successAlert.classList.remove("hidden");
                successAlert.classList.add("flex");
                form.reset();
            } else {
                const error = await res.text();
                errorsText.textContent = error;
    
                errorsAlert.classList.remove("hidden");
                errorsAlert.classList.add("flex");
                form.reset();
            }
        });
    });
    </script>
    

<style>
    .edit-form-input:focus {
        outline: none;
        border-color: #01348580;
        box-shadow: 0 0 0 2px rgba(1, 52, 133, 0.15);
        transition: all 0.2s ease-in-out;
    }
</style>
